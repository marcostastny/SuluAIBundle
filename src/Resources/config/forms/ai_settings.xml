<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>ai_settings</key>
    <properties>
        <property name="enabled" type="checkbox">
            <meta>
                <title>sulu_ai.enabled</title>
            </meta>
            <params>
                <param name="type" value="toggler"/>
            </params>
        </property>
        <property name="apiUrl" type="text_line" colspan="6">
            <meta>
                <title>sulu_ai.api_url</title>
                <info_text>sulu_ai.api_url_info</info_text>
            </meta>
        </property>
        <property name="model" type="text_line" colspan="6">
            <meta>
                <title>sulu_ai.model</title>
                <info_text>sulu_ai.model_info</info_text>
            </meta>
        </property>
        <property name="apiKey" type="password" colspan="12">
            <meta>
                <title>sulu_ai.api_key</title>
            </meta>
        </property>
        <property name="agentName" type="text_line" colspan="6">
            <meta>
                <title>sulu_ai.agent_name</title>
                <info_text>sulu_ai.agent_name_info</info_text>
            </meta>
        </property>
        <property name="personality" type="single_select" colspan="6">
            <meta>
                <title>sulu_ai.personality</title>
            </meta>
            <params>
                <param name="default_value" value="neutral"/>
                <param name="values" type="collection">
                    <param name="neutral">
                        <meta>
                            <title>sulu_ai.personality_neutral</title>
                        </meta>
                    </param>
                    <param name="professional">
                        <meta>
                            <title>sulu_ai.personality_professional</title>
                        </meta>
                    </param>
                    <param name="friendly">
                        <meta>
                            <title>sulu_ai.personality_friendly</title>
                        </meta>
                    </param>
                    <param name="concise">
                        <meta>
                            <title>sulu_ai.personality_concise</title>
                        </meta>
                    </param>
                    <param name="playful">
                        <meta>
                            <title>sulu_ai.personality_playful</title>
                        </meta>
                    </param>
                    <param name="formal">
                        <meta>
                            <title>sulu_ai.personality_formal</title>
                        </meta>
                    </param>
                </param>
            </params>
        </property>
        <property name="customPrompt" type="text_area" colspan="12">
            <meta>
                <title>sulu_ai.custom_prompt</title>
                <info_text>sulu_ai.custom_prompt_info</info_text>
            </meta>
        </property>
        <property name="dataQueryTables" type="text_area" colspan="12">
            <meta>
                <title>sulu_ai.data_query_tables</title>
                <info_text>sulu_ai.data_query_tables_info</info_text>
            </meta>
        </property>
        <property name="imageStylePrompt" type="text_area" colspan="12">
            <meta>
                <title>sulu_ai.image_style_prompt</title>
                <info_text>sulu_ai.image_style_prompt_info</info_text>
            </meta>
        </property>
        <property name="imageModels" type="block" minOccurs="0" colspan="12">
            <meta>
                <title>sulu_ai.image_models</title>
                <info_text>sulu_ai.image_models_info</info_text>
            </meta>
            <types>
                <type name="model">
                    <meta>
                        <title>sulu_ai.image_model</title>
                    </meta>
                    <properties>
                        <property name="label" type="text_line" colspan="6">
                            <meta>
                                <title>sulu_ai.image_model_label</title>
                            </meta>
                        </property>
                        <property name="modelId" type="text_line" colspan="6">
                            <meta>
                                <title>sulu_ai.image_model_id</title>
                            </meta>
                        </property>
                        <property name="supportsReference" type="checkbox" colspan="6">
                            <meta>
                                <title>sulu_ai.image_model_supports_reference</title>
                            </meta>
                            <params>
                                <param name="type" value="toggler"/>
                            </params>
                        </property>
                        <property name="maxImages" type="number" colspan="6">
                            <meta>
                                <title>sulu_ai.image_model_max_images</title>
                            </meta>
                        </property>
                    </properties>
                </type>
            </types>
        </property>
    </properties>
</form>
